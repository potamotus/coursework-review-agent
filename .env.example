# Copy to `.env` and fill in. The `.env` file is gitignored.

# Google Spreadsheet ID containing your tasks table
# (from the URL between /d/ and /edit)
REVIEW_SPREADSHEET_ID=your_spreadsheet_id_here

# Name of the sheet tab where the tasks table lives
# The tool expects this exact column layout (B..G):
#   B: task number/ID
#   C: task title
#   D: assignee name
#   E: reviewer name
#   F: status (e.g. "Done")
#   G: artifact URL (Google Docs link)
REVIEW_TASKS_SHEET=Tasks

# Range of the tasks table within the sheet (body rows only, no header)
REVIEW_TASKS_RANGE=B4:G50

# Status value that marks a task as ready for review
REVIEW_STATUS_READY=Done

# Optional overrides (sensible defaults if omitted)
# REVIEW_KEY_PATH=./key.json
# REVIEW_METHODOLOGY_PATH=./methodology/methodology.md
# REVIEW_AI_REVIEWS_DIR=./AI_reviews
